# ============================================================
# Lead-to-Website Automation — Configuration
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env file. On Hugging Face, set these
# as "Repository secrets" in the Space settings instead.
# ============================================================

# --- AgentRouter (gives access to Claude Opus 4.x) ---
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
AGENTROUTER_API_KEY=sk-your-agentrouter-key
# The exact model id your AgentRouter exposes for Opus 4.x:
AGENTROUTER_MODEL=claude-opus-4-8

# --- Google Places API (lead source) ---
GOOGLE_PLACES_API_KEY=your-google-places-key
# Where to search for leads, and what kind of business:
LEAD_SEARCH_QUERY=salon in Chennai
LEAD_REGION=Chennai, Tamil Nadu, India
LEAD_AI_QUERIES=true
# How wide/how many per run:
LEAD_MAX_RESULTS=10

# ============================================================
# --- Publishing: choose ONE provider ---
# "cloudflare" = Cloudflare Pages: UNLIMITED free sites/bandwidth,
#                no sudden project caps (recommended for 24/7 use).
# "netlify"    = Netlify (kept for compatibility; has free-tier limits).
DEPLOY_PROVIDER=cloudflare

# --- Cloudflare Pages (used when DEPLOY_PROVIDER=cloudflare) ---
# 1. Create an API token: Cloudflare dashboard -> My Profile -> API Tokens
#    -> Create Token -> permission: Account · Cloudflare Pages · Edit.
# 2. Account ID: dashboard right sidebar, or from the URL
#    https://dash.cloudflare.com/<ACCOUNT_ID>/pages
# Every business is published to ONE project on its own branch, so each gets a
# stable URL like https://<business>.<project>.pages.dev (no per-project cap).
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_PAGES_PROJECT=lead-sites

# --- Netlify (used when DEPLOY_PROVIDER=netlify) ---
NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token
# ============================================================

# --- Database (persistence) ---
# Leave BLANK to use a local SQLite file (fine for local dev).
# On Hugging Face free Spaces the disk is EPHEMERAL (resets on rebuild/sleep),
# so set a free Postgres URL to keep your lead history (Supabase / Neon / Railway):
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# --- WhatsApp (outreach) ---
# We DRAFT the message + a wa.me click-to-chat link in the dashboard.
WHATSAPP_FROM_NUMBER=+10000000000

# --- Worker loop ---
# Seconds to wait between processing each lead (be polite to APIs):
WORKER_INTERVAL_SECONDS=30
