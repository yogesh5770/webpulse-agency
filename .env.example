# ============================================================
# Lead-to-Website Automation — Configuration
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env file. On Hugging Face, set these
# as "Repository secrets" in the Space settings instead.
# ============================================================

# --- AgentRouter (access to GLM 5.2, Claude, etc.) ---
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
AGENTROUTER_API_KEY=sk-your-agentrouter-key
# Model id: glm-5-2 (or any other model AgentRouter exposes)
AGENTROUTER_MODEL=glm-5-2

# --- Google Places API (lead source) ---
GOOGLE_PLACES_API_KEY=your-google-places-key
# Where to search for leads, and what kind of business:
LEAD_SEARCH_QUERY=salon in Chennai
LEAD_REGION=Chennai, Tamil Nadu, India
LEAD_AI_QUERIES=true
# How wide/how many per run:
LEAD_MAX_RESULTS=10

# ============================================================
# --- Publishing: Cloudflare Pages (client sites) ---
# All generated client sites are published to Cloudflare Pages: UNLIMITED free
# sites/bandwidth, no per-project caps (built for 24/7 use).
# 1. Create an API token: Cloudflare dashboard -> My Profile -> API Tokens
#    -> Create Token -> permission: Account · Cloudflare Pages · Edit.
# 2. Account ID: dashboard right sidebar, or from the URL
#    https://dash.cloudflare.com/<ACCOUNT_ID>/pages
# Every business is published to ONE project on its own branch, so each gets a
# stable URL like https://<business>.<project>.pages.dev (no per-project cap).
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_PAGES_PROJECT=lead-sites
# ============================================================

# --- Database (persistence) ---
# Leave BLANK to use a local SQLite file (fine for quick local dev).
# For production, use Neon serverless Postgres (free tier). Paste the POOLED
# connection string from the Neon dashboard; keep sslmode=require:
#   DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/leads?sslmode=require
DATABASE_URL=

# --- WhatsApp (outreach) ---
# We DRAFT the message + a wa.me click-to-chat link in the dashboard.
WHATSAPP_FROM_NUMBER=+10000000000

# --- Worker loop ---
# Seconds to wait between processing each lead (be polite to APIs):
WORKER_INTERVAL_SECONDS=30

# --- AWS Bedrock API (optional, either credentials OR API key OR bearer token) ---
# Option 1: AWS credentials (for real Bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
# Option 2: API key (for Bedrock proxy)
BEDROCK_API_KEY=your-bedrock-api-key
# Option 3: Bearer token (for Bedrock proxy with long-term API keys)
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-bearer-token
BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com
